# =============================================================================
# Build / binary artifacts
# =============================================================================
*.exe
*.dll
*.o
*.out
*.bin
*.app
*.rpm
*.deb
*.msi
*.dmg
*.pkg
*.apk

# =============================================================================
# Disk images & VM artifacts
# =============================================================================
*.vhd
*.vhdx
*.vmdk
*.vdi
*.qcow2
*.img
*.raw
*.iso
*.rom

# =============================================================================
# Archives
# =============================================================================
*.tar
*.tar.gz
*.tar.bz2
*.gz
*.7z
*.zip

# =============================================================================
# Logs & temp files
# =============================================================================
*.log
*.tmp
*.bak
*.swp
*.swo
*.cache

# =============================================================================
# OS & editor junk
# =============================================================================
.DS_Store

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.pyc

# =============================================================================
# Secrets & local config (NEVER commit)
# =============================================================================
*.env
*.local

# =============================================================================
# Terraform — sensitive / generated files
# =============================================================================
# State files contain credentials, tokens, and resource IDs
*.tfstate
*.tfstate.*
# The actual variable values file often has tokens/passwords
terraform.tfvars
# Provider binaries (large, machine-specific)
.terraform/
# Override files used for local dev
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# Crash logs
crash.log
crash.*.log
# Plan output files
*.tfplan

# =============================================================================
# Project-specific
# =============================================================================
archive/




